---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Offline · smallweb">
  <Header currentPath="/offline" tag="a moment without the network" />

  <main class="offline">
    <span class="eyebrow" data-cat="life">Offline</span>
    <h1>You appear to be <em>offline</em>.</h1>
    <p class="lede">It looks like the connection has dropped. Previously visited pages may still be available — try going back, or wait a moment and reload.</p>
    <a class="back" href="/">Try again →</a>
  </main>

  <Footer left="Offline · smallweb" colophon="The quieter corner, quietened further." />
</Base>

<style>
  .offline {
    max-width: 58ch;
    padding: 64px 0 96px;
    text-align: left;
  }
  .offline h1 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(44px, 7vw, 88px);
    line-height: 0.9;
    letter-spacing: -0.035em;
    margin: 14px 0 22px;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    color: var(--ink);
  }
  .offline h1 em { font-style: italic; color: var(--accent); }
  .offline .lede {
    font-size: 19px;
    line-height: 1.65;
    color: var(--ink-2);
    margin-bottom: 32px;
  }
  .offline .back {
    font-family: var(--sans);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 12px 20px;
    border: 1px solid var(--ink);
    color: var(--ink);
    display: inline-block;
    transition: background 160ms ease, color 160ms ease;
  }
  .offline .back:hover { background: var(--ink); color: var(--paper); }
</style>
