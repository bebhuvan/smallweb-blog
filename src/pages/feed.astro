---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getBlogMap, getBlogs, getEnrichedPosts } from '../lib/site-data';
import { CATEGORY_MAP, type CategorySlug } from '../lib/categories';
import { formatDate } from '../lib/dates';

const FEED_LIMIT = 500;

const blogs = getBlogs();
const blogMap = getBlogMap(blogs);
const allPosts = getEnrichedPosts({ blogs, blogMap })
  .filter((p) => !Number.isNaN(new Date(p.date).getTime()))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const totalPosts = allPosts.length;
const enrichedPosts = allPosts.slice(0, FEED_LIMIT);

function truncate(text: string | undefined, max: number) {
  if (!text) return '';
  const t = text.trim();
  return t.length <= max ? t : `${t.slice(0, max).trimEnd()}…`;
}
---

<Base title="Feed — smallweb" description="Every essay, as it lands.">
  <Header currentPath="/feed" tag="every essay, as it lands" />

  <main>

    <section class="feed-hero">
      <div>
        <span class="eyebrow" data-cat="science">The feed</span>
        <h1>Every <em>essay</em>, as it lands.</h1>
        <p class="feed-sub">
          Chronological. No algorithm. Read it here, or
          <a href="/rss.xml" type="application/rss+xml">subscribe by RSS</a>.
        </p>
      </div>
      <div class="count">
        latest <b class="figures">{enrichedPosts.length}</b> of <b class="figures">{totalPosts.toLocaleString()}</b> · {blogs.length} writers
      </div>
    </section>

    <div class="feed-list">
      {enrichedPosts.map((post) => (
        <a class="feed-row" data-cat={post.category} href={post.link} target="_blank" rel="noopener noreferrer">
          <div class="fr-meta">
            <span class="fr-cat">{CATEGORY_MAP.get(post.category as CategorySlug)?.name || post.category}</span>
            <span class="fr-date figures">{formatDate(post.date)}</span>
          </div>
          <h3 class="fr-title">{post.title}</h3>
          {post.excerpt && <p class="fr-excerpt">{truncate(post.excerpt, 220)}</p>}
          <div class="fr-byline">{post.blogName}</div>
        </a>
      ))}
    </div>

  </main>

  <Footer left="Feed · smallweb" colophon="Chronological. No algorithm." />
</Base>

<style>
  .feed-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: end;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--rule);
  }
  .feed-hero h1 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(44px, 7vw, 92px);
    line-height: 0.86;
    letter-spacing: -0.035em;
    margin: 10px 0 0;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    color: var(--ink);
  }
  .feed-hero h1 em { font-style: italic; color: var(--accent); }
  .feed-sub {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(17px, 1.8vw, 19px);
    line-height: 1.4;
    color: var(--ink-2);
    margin: 18px 0 0;
    max-width: 52ch;
    font-variation-settings: "opsz" 144;
  }
  .feed-sub a {
    color: var(--accent);
    border-bottom: 1px solid var(--rule);
    transition: border-color 160ms ease;
  }
  .feed-sub a:hover { border-bottom-color: var(--accent); }
  .feed-hero .count {
    font-family: var(--serif-display);
    font-style: italic;
    font-size: clamp(18px, 2.2vw, 24px);
    color: var(--dim);
    padding-bottom: 12px;
  }
  .feed-hero .count b { color: var(--accent); font-weight: 300; }

  .feed-list { display: flex; flex-direction: column; padding-top: 48px; }
  .feed-row {
    padding: 40px 0;
    border-bottom: 1px dotted var(--rule);
    color: inherit;
    display: block;
    transition: padding-left 220ms ease;
  }
  .feed-row:last-child { border-bottom: 0; }
  .feed-row:hover { padding-left: 16px; }
  .feed-row:hover .fr-title { color: var(--accent); }

  .fr-meta {
    display: flex;
    justify-content: space-between;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 10px;
  }
  .feed-row[data-cat] .fr-cat { font-weight: 600; }
  .feed-row[data-cat="tech"]       .fr-cat { color: var(--tech); }
  .feed-row[data-cat="culture"]    .fr-cat { color: var(--culture); }
  .feed-row[data-cat="economics"]  .fr-cat { color: var(--economics); }
  .feed-row[data-cat="finance"]    .fr-cat { color: var(--finance); }
  .feed-row[data-cat="life"]       .fr-cat { color: var(--life); }
  .feed-row[data-cat="philosophy"] .fr-cat { color: var(--philosophy); }
  .feed-row[data-cat="psychology"] .fr-cat { color: var(--psychology); }
  .feed-row[data-cat="design"]     .fr-cat { color: var(--design); }
  .feed-row[data-cat="history"]    .fr-cat { color: var(--history); }
  .feed-row[data-cat="science"]    .fr-cat { color: var(--science); }

  .fr-title {
    font-family: var(--serif-display);
    font-weight: 400;
    font-size: clamp(20px, 2.6vw, 26px);
    line-height: 1.2;
    letter-spacing: -0.012em;
    color: var(--ink);
    margin: 0 0 8px;
    transition: color 180ms ease;
  }
  .fr-excerpt {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 12px;
    max-width: 62ch;
  }
  .fr-byline {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-2);
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .feed-hero { grid-template-columns: 1fr; gap: 12px; padding-bottom: 32px; }
    .fr-title { font-size: 19px; }
    .feed-row { padding: 22px 0; }
  }
</style>
