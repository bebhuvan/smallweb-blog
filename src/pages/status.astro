---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getBlogs, getStatusCacheSafe } from '../lib/site-data';

const statusData = await getStatusCacheSafe();

const blogs = getBlogs();
const blogMap = new Map(blogs.map((b) => [b.id, b]));
const hasErrors = (statusData.summary?.errors || 0) > 0;

const enrichedFeeds = statusData.feeds
  .map((feed: any) => {
    const blog = blogMap.get(feed.blogId);
    return {
      ...feed,
      name: blog?.name || feed.blogId,
      url: blog?.url || '',
      feedUrl: blog?.feed || '',
    };
  })
  .sort((a: any, b: any) => {
    if (a.status !== b.status) return a.status === 'error' ? -1 : 1;
    return a.name.localeCompare(b.name);
  });

function formatStatusDate(dateStr: string | null) {
  if (!dateStr) return 'Never';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

function latencyColor(ms: number) {
  if (!ms) return 'var(--dim)';
  if (ms < 1000) return 'var(--tech)';
  if (ms < 3000) return 'var(--economics)';
  return 'var(--accent)';
}
---

<Base title="Status · smallweb" description="Health of every RSS feed in the library.">
  <Header currentPath="/status" tag={`monitoring ${statusData.summary.total} feeds`} />

  <main>

    <section class="status-hero">
      <div>
        <span class="eyebrow" data-cat="science">Status</span>
        <h1>Feed <em>health</em>.</h1>
      </div>
      <div class="last-updated">
        Last refreshed<br />
        <b>{formatStatusDate(statusData.lastUpdated)}</b>
      </div>
    </section>

    {hasErrors && (
      <div class="alert">
        Some feeds failed in the latest refresh. The site keeps serving the last successful data until the next refresh.
      </div>
    )}

    <section class="summary">
      <div class="s">
        <span class="s-label">Healthy</span>
        <div class="s-val" style="color: var(--finance);">{statusData.summary.healthy}</div>
      </div>
      <div class="s">
        <span class="s-label">Errors</span>
        <div class="s-val" style={`color: ${hasErrors ? 'var(--accent)' : 'var(--dim)'};`}>{statusData.summary.errors}</div>
      </div>
      <div class="s">
        <span class="s-label">Total</span>
        <div class="s-val">{statusData.summary.total}</div>
      </div>
    </section>

    <section class="feeds">
      <div class="section-head">
        <h2>All <em>feeds</em></h2>
        <small>{enrichedFeeds.length} monitored</small>
      </div>
      <div class="feed-list">
        {enrichedFeeds.map((feed: any) => (
          <div class="feed-row" data-status={feed.status}>
            <span class="dot" aria-hidden="true"></span>
            <div class="name">
              {feed.name}
              {feed.status === 'error' && feed.error && (
                <div class="err">{feed.error}</div>
              )}
            </div>
            <span class="posts figures">{feed.postCount}</span>
            <span class="lat figures" style={`color: ${latencyColor(feed.latencyMs)};`}>{feed.latencyMs || 0}ms</span>
          </div>
        ))}
      </div>
    </section>

    <p class="note">Feeds are refreshed automatically several times a day via GitHub Actions.</p>

  </main>

  <Footer left="Status · smallweb" colophon="A small dashboard for a quiet library." />
</Base>

<style>
  .status-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: end;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--rule);
  }
  .status-hero h1 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(44px, 7vw, 88px);
    line-height: 0.9;
    letter-spacing: -0.035em;
    margin: 10px 0 0;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    color: var(--ink);
  }
  .status-hero h1 em { font-style: italic; color: var(--accent); }
  .last-updated {
    font-family: var(--sans);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    text-align: right;
    line-height: 1.8;
    padding-bottom: 12px;
  }
  .last-updated b { color: var(--ink); font-weight: 600; letter-spacing: 0.12em; }

  .alert {
    margin: 32px 0;
    padding: 14px 20px;
    border-left: 2px solid var(--accent);
    color: var(--accent);
    font-family: var(--serif-display);
    font-style: italic;
    font-size: 16px;
    line-height: 1.5;
    background: var(--paper-2);
  }

  .summary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    margin: 48px 0;
  }
  .summary .s {
    padding: 32px 24px;
    border-right: 1px solid var(--rule);
  }
  .summary .s:last-child { border-right: 0; }
  .summary .s-label {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 600;
    margin-bottom: 16px;
    display: block;
  }
  .summary .s-val {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: 52px;
    line-height: 0.9;
    color: var(--ink);
    font-feature-settings: "tnum", "lnum";
  }

  .feeds { margin-top: 56px; }
  .feed-list { display: flex; flex-direction: column; }
  .feed-row {
    display: grid;
    grid-template-columns: 14px 1fr auto 80px;
    gap: 24px;
    padding: 14px 0;
    border-bottom: 1px dotted var(--rule);
    align-items: baseline;
    font-family: var(--sans);
    font-size: 12px;
  }
  .feed-row .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--finance);
    align-self: center;
  }
  .feed-row[data-status="error"] .dot { background: var(--accent); }
  .feed-row .name {
    font-family: var(--serif-display);
    font-size: 18px;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.2;
  }
  .feed-row .err {
    margin-top: 4px;
    font-family: var(--sans);
    font-size: 11px;
    color: var(--accent);
    text-transform: none;
    letter-spacing: 0;
  }
  .feed-row .posts {
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .feed-row .lat {
    text-align: right;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .note {
    margin-top: 48px;
    font-family: var(--serif-display);
    font-style: italic;
    color: var(--dim);
    font-size: 14px;
  }

  @media (max-width: 980px) {
    .status-hero { grid-template-columns: 1fr; gap: 12px; }
    .last-updated { text-align: left; padding-bottom: 0; }
    .summary { grid-template-columns: 1fr; }
    .summary .s { border-right: 0; border-bottom: 1px solid var(--rule); padding: 24px 0; }
    .summary .s:last-child { border-bottom: 0; }
    .summary .s-val { font-size: 42px; }
    .feed-row { grid-template-columns: 14px 1fr auto; gap: 16px; }
    .feed-row .lat { grid-column: 2 / 4; text-align: left; margin-top: 4px; }
  }
</style>
