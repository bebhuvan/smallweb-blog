---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getBlogMap, getBlogs, getPosts } from '../../lib/site-data';
import { enrichPosts } from '../../lib/posts';
import { CATEGORY_MAP, type CategorySlug } from '../../lib/categories';

export function getStaticPaths() {
  return getBlogs().map((blog) => ({
    params: { slug: blog.id },
    props: { blog },
  }));
}

interface Blog {
  id: string;
  name: string;
  url: string;
  feed?: string;
  categories: string[];
  description: string;
  proxy?: boolean;
}

const { blog } = Astro.props as { blog: Blog };
const blogs = getBlogs();
const blogMap = getBlogMap(blogs);

const posts = enrichPosts(
  getPosts().filter((p) => p.blogId === blog.id),
  blogMap
).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const primaryCat = (blog.categories?.[0] || 'tech') as CategorySlug;
const primaryCatDef = CATEGORY_MAP.get(primaryCat);

const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).getTime();
const postsThisMonth = posts.filter((p) => new Date(p.date).getTime() >= monthStart).length;

const librarySince = posts.length
  ? new Date(Math.min(...posts.map((p) => new Date(p.date).getTime())))
  : null;

function avgReadingMinutes(items: { excerpt?: string }[]) {
  if (!items.length) return 0;
  const total = items.reduce((acc, p) => {
    const words = (p.excerpt || '').split(/\s+/).length;
    return acc + Math.max(1, Math.round(words / 200) + 5);
  }, 0);
  return Math.round(total / items.length);
}

function shortDate(dateStr: string) {
  const d = new Date(dateStr);
  if (Number.isNaN(d.getTime())) return '';
  return d.toLocaleDateString('en-US', { month: 'short', day: '2-digit' });
}

function truncate(text: string | undefined, max: number) {
  if (!text) return '';
  const t = text.trim();
  return t.length <= max ? t : `${t.slice(0, max).trimEnd()}…`;
}

function readingMinutes(post: { excerpt?: string }) {
  const words = (post.excerpt || '').split(/\s+/).length;
  return Math.max(1, Math.round(words / 200) + 5);
}

const avgMin = avgReadingMinutes(posts);
const latestPost = posts[0];
const feedHref = blog.feed || blog.url;

const visiblePosts = posts.slice(0, 30);
---

<Base title={`${blog.name} — smallweb`} description={blog.description} ogType="profile">
  <Header
    currentPath={`/blog/${blog.id}`}
    tag={`${primaryCatDef?.name || primaryCat} · ${blog.categories?.length || 1} shelves`}
  />

  <main style={`--writer-color: var(--${primaryCat});`}>

    <section class="writer-hero">
      <div class="writer-hero-block">
        <div class="eyebrow-row">
          {(blog.categories || []).map((c) => (
            <span class="eyebrow" data-cat={c}>{CATEGORY_MAP.get(c as CategorySlug)?.name || c}</span>
          ))}
        </div>
        <h1>{blog.name}<em>.</em></h1>
        <p class="bio">{blog.description}</p>
        <div class="writer-actions">
          {latestPost && (
            <a class="primary" href={latestPost.link} target="_blank" rel="noopener noreferrer">Read latest →</a>
          )}
          {blog.feed && (
            <a href={feedHref} target="_blank" rel="noopener noreferrer">Subscribe via RSS</a>
          )}
          <a href={blog.url} target="_blank" rel="noopener noreferrer">Visit site</a>
        </div>
      </div>

      <aside class="writer-stats">
        <dl>
          <div>
            <dt>In the library since</dt>
            <dd>{librarySince ? librarySince.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : '—'}</dd>
          </div>
          <div>
            <dt>Essays indexed</dt>
            <dd class="figures">{posts.length}</dd>
          </div>
          <div>
            <dt>This month</dt>
            <dd class="figures">{postsThisMonth} <small>essays</small></dd>
          </div>
          <div>
            <dt>Average read</dt>
            <dd class="figures">{avgMin || '—'} <small>minutes</small></dd>
          </div>
        </dl>
      </aside>
    </section>

    <section class="writer-posts">
      <div class="section-head">
        <h2>Recent <em>essays</em></h2>
        <small>{visiblePosts.length} of {posts.length}</small>
      </div>

      {posts.length === 0 && (
        <p class="empty">No essays from this writer yet.</p>
      )}

      {visiblePosts.map((post) => (
        <a class="post-item" href={post.link} target="_blank" rel="noopener noreferrer">
          <div class="post-meta-left">
            <span class="date">{shortDate(post.date)}</span>
            <span class="time">{readingMinutes(post)} min</span>
          </div>
          <div class="post-body">
            <h3 class="post-title">{post.title}</h3>
            {post.excerpt && <p class="post-excerpt">{truncate(post.excerpt, 260)}</p>}
          </div>
        </a>
      ))}
    </section>

  </main>

  <Footer left={`Writer · ${blog.name}`} colophon={blog.description} />
</Base>

<style>
  /* ─── page-local: writer page ─── */
  .writer-hero {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 80px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--rule);
  }
  .writer-hero-block .eyebrow-row {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }
  .writer-hero-block h1 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(46px, 7.5vw, 104px);
    line-height: 0.86;
    letter-spacing: -0.035em;
    margin: 20px 0 14px;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    color: var(--ink);
    word-break: break-word;
  }
  .writer-hero-block h1 em { font-style: italic; color: var(--writer-color); }
  .writer-hero-block .bio {
    font-size: 17px;
    line-height: 1.64;
    color: var(--ink-2);
    max-width: 58ch;
    margin: 0 0 24px;
  }
  .writer-hero-block .writer-actions {
    display: flex;
    gap: 14px;
    margin-top: 24px;
    flex-wrap: wrap;
  }
  .writer-hero-block .writer-actions a {
    font-family: var(--sans);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 10px 16px;
    border: 1px solid var(--ink);
    color: var(--ink);
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }
  .writer-hero-block .writer-actions a:hover {
    background: var(--ink);
    color: var(--paper);
  }
  .writer-hero-block .writer-actions a.primary {
    background: var(--writer-color);
    border-color: var(--writer-color);
    color: var(--paper);
  }
  .writer-hero-block .writer-actions a.primary:hover {
    background: var(--ink);
    border-color: var(--ink);
  }

  .writer-stats {
    border-left: 1px solid var(--rule);
    padding-left: 56px;
    padding-top: 12px;
  }
  .writer-stats dl {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .writer-stats dt {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 600;
    margin-bottom: 6px;
  }
  .writer-stats dd {
    margin: 0;
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--ink);
    font-variation-settings: "opsz" 144;
    font-feature-settings: "tnum", "lnum";
  }
  .writer-stats dd small {
    font-family: var(--serif-display);
    font-size: 13px;
    font-weight: 400;
    font-style: italic;
    color: var(--dim);
    letter-spacing: 0;
    margin-left: 6px;
    text-transform: none;
  }

  .writer-posts { padding-top: 96px; }
  .post-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 48px;
    padding: 44px 0;
    border-bottom: 1px dotted var(--rule);
    align-items: baseline;
    text-decoration: none;
    color: inherit;
    transition: padding-left 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .post-item:last-child { border-bottom: 0; }
  .post-item:hover { padding-left: 16px; }
  .post-item:hover .post-title { color: var(--accent); }

  .post-meta-left {
    text-align: right;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
    line-height: 1.8;
    padding-top: 6px;
  }
  .post-meta-left .date {
    font-family: var(--serif-display);
    font-style: italic;
    font-size: 22px;
    font-weight: 300;
    text-transform: none;
    color: var(--ink);
    display: block;
    margin-bottom: 8px;
    font-variation-settings: "opsz" 144;
    font-feature-settings: "tnum", "lnum";
  }
  .post-meta-left .time { display: block; color: var(--writer-color); font-weight: 600; }

  .post-body { padding-top: 4px; }
  .post-title {
    font-family: var(--serif-display);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 28px);
    line-height: 1.18;
    letter-spacing: -0.012em;
    margin: 0 0 12px;
    color: var(--ink);
    transition: color 180ms ease;
  }
  .post-excerpt {
    font-size: 16px;
    line-height: 1.68;
    color: var(--ink-2);
    margin: 12px 0 0;
    max-width: 60ch;
  }

  .empty {
    padding: 48px 0;
    color: var(--dim);
    font-style: italic;
  }

  @media (max-width: 980px) {
    .writer-hero { grid-template-columns: 1fr; gap: 40px; padding-bottom: 40px; }
    .writer-hero-block h1 { font-size: clamp(40px, 10vw, 64px); }
    .writer-stats { border-left: 0; border-top: 1px solid var(--rule); padding: 32px 0 0; }
    .writer-stats dl { flex-direction: row; flex-wrap: wrap; gap: 28px 40px; }
    .post-item { grid-template-columns: 1fr; gap: 10px; padding: 24px 0; }
    .post-meta-left { text-align: left; padding-top: 0; display: flex; gap: 14px; flex-wrap: wrap; }
    .post-meta-left .date { display: inline; margin: 0; font-size: 18px; }
    .post-title { font-size: 22px; }
    .writer-posts { padding-top: 48px; }
  }
</style>
