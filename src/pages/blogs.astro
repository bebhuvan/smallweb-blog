---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CATEGORIES, CATEGORY_MAP, type CategorySlug } from '../lib/categories';
import { getBlogs, getPosts } from '../lib/site-data';

const blogs = getBlogs();
const posts = getPosts();

const postCounts = new Map<string, number>();
posts.forEach((p) => postCounts.set(p.blogId, (postCounts.get(p.blogId) || 0) + 1));

const enrichedBlogs = blogs
  .map((blog) => ({ ...blog, postCount: postCounts.get(blog.id) || 0 }))
  .sort((a, b) => a.name.localeCompare(b.name));

const blogsByCategory = new Map<string, typeof enrichedBlogs>();
for (const b of enrichedBlogs) {
  const primary = b.categories?.[0] || 'tech';
  if (!blogsByCategory.has(primary)) blogsByCategory.set(primary, []);
  blogsByCategory.get(primary)!.push(b);
}

function host(url: string) {
  try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return url; }
}
---

<Base title="Writers — smallweb" description="Every indie blog indexed by smallweb, grouped by department.">
  <Header currentPath="/blogs" tag={`${blogs.length} writers across ${blogsByCategory.size} shelves`} />

  <main>

    <section class="writers-hero">
      <div>
        <span class="eyebrow" data-cat="culture">The library</span>
        <h1>The <em>writers</em>.</h1>
        <p class="lede">Every blog in the library, grouped by shelf. Click a name to read their recent essays; click the domain to visit their site.</p>
      </div>
      <div class="count">
        <b class="figures">{blogs.length}</b> writers · {blogsByCategory.size} shelves
      </div>
    </section>

    {CATEGORIES.map((category) => {
      const items = blogsByCategory.get(category.slug);
      if (!items || items.length === 0) return null;
      return (
        <section class="shelf" style={`--category-color: var(${category.colorVar});`}>
          <div class="shelf-head">
            <h2>{category.name}<em>.</em></h2>
            <span class="shelf-count"><span class="figures">{items.length}</span> writers</span>
          </div>
          <ul class="writer-list">
            {items.map((b) => (
              <li>
                <a class="writer-row" href={`/blog/${b.id}`}>
                  <span class="w-name">{b.name}</span>
                  <span class="w-host">{host(b.url)}</span>
                  <span class="w-count figures">{b.postCount}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      );
    })}

  </main>

  <Footer left="Writers · smallweb" colophon={`${blogs.length} hand-picked blogs, in one quiet room.`} />
</Base>

<style>
  .writers-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: end;
    padding-bottom: 56px;
    border-bottom: 1px solid var(--rule);
  }
  .writers-hero h1 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(52px, 8vw, 108px);
    line-height: 0.86;
    letter-spacing: -0.035em;
    margin: 10px 0 22px;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    color: var(--ink);
  }
  .writers-hero h1 em { font-style: italic; color: var(--accent); }
  .writers-hero .lede {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: 20px;
    line-height: 1.4;
    color: var(--ink-2);
    max-width: 52ch;
    margin: 0;
  }
  .writers-hero .count {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(18px, 2.2vw, 28px);
    color: var(--dim);
    padding-bottom: 12px;
  }
  .writers-hero .count b { color: var(--accent); font-weight: 300; }

  .shelf { padding: 56px 0 24px; border-bottom: 1px solid var(--rule); }
  .shelf:last-of-type { border-bottom: 0; }
  .shelf-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 18px;
    margin-bottom: 8px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .shelf-head h2 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(32px, 5vw, 54px);
    line-height: 0.9;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
    font-variation-settings: "opsz" 144;
  }
  .shelf-head h2 em { font-style: italic; color: var(--category-color); }
  .shelf-count {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 600;
  }

  .writer-list { list-style: none; margin: 0; padding: 0; }
  .writer-row {
    display: grid;
    grid-template-columns: 1fr auto 60px;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px dotted var(--rule);
    align-items: baseline;
    color: inherit;
    transition: padding-left 200ms ease;
    position: relative;
  }
  .writer-row::before {
    content: "";
    position: absolute;
    left: 0; top: 50%;
    width: 0;
    height: 1px;
    background: var(--category-color);
    transition: width 220ms ease;
  }
  .writer-row:hover { padding-left: 16px; }
  .writer-row:hover::before { width: 10px; }
  .writer-row:hover .w-name { color: var(--accent); }
  .w-name {
    font-family: var(--serif-display);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--ink);
    transition: color 180ms ease;
  }
  .w-host {
    font-family: var(--sans);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .w-count {
    font-family: var(--sans);
    font-size: 11px;
    color: var(--dim);
    text-align: right;
  }

  @media (max-width: 980px) {
    .writers-hero { grid-template-columns: 1fr; gap: 12px; padding-bottom: 40px; }
    .writers-hero h1 { font-size: clamp(44px, 14vw, 72px); }
    .writer-row { grid-template-columns: 1fr auto; gap: 4px 16px; padding: 14px 0; }
    .w-host { grid-column: 1; font-size: 10px; }
    .w-count { grid-column: 2; grid-row: 1 / span 2; align-self: center; }
  }
</style>
