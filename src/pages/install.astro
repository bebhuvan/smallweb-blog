---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Install · smallweb" description="Add smallweb to your home screen as a lightweight app.">
  <Header currentPath="/install" tag="offline reading, on any screen" />

  <main>
    <section class="install-hero">
      <span class="eyebrow" data-cat="tech">Install</span>
      <h1>A shortcut on your <em>home screen</em>.</h1>
      <p class="lede">Smallweb works as a lightweight, offline-friendly app. No App Store required — Safari and Chrome can add it directly from the browser.</p>
    </section>

    <section class="install-steps">
      <article>
        <h2>iPhone &amp; iPad <small>Safari</small></h2>
        <ol>
          <li>Open <b>smallweb.blog</b> in Safari.</li>
          <li>Tap the <b>Share</b> button.</li>
          <li>Choose <b>Add to Home Screen</b>.</li>
          <li>Name it and tap <b>Add</b>.</li>
        </ol>
      </article>

      <article>
        <h2>Android <small>Chrome</small></h2>
        <ol>
          <li>Open <b>smallweb.blog</b> in Chrome.</li>
          <li>Tap the menu (three dots).</li>
          <li>Select <b>Install app</b> or <b>Add to Home screen</b>.</li>
        </ol>
      </article>

      <article>
        <h2>Desktop <small>Chrome · Edge</small></h2>
        <ol>
          <li>Open <b>smallweb.blog</b>.</li>
          <li>Click the <b>Install</b> icon in the address bar.</li>
          <li>Confirm the install.</li>
        </ol>
      </article>
    </section>

    <blockquote class="tip">
      The app works best after your first visit — it caches key pages and loads faster next time.
    </blockquote>
  </main>

  <Footer left="Install · smallweb" colophon="A quiet reader, in your pocket." />
</Base>

<style>
  .install-hero {
    max-width: 56ch;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--rule);
  }
  .install-hero h1 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(44px, 7vw, 88px);
    line-height: 0.9;
    letter-spacing: -0.035em;
    margin: 14px 0 22px;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    color: var(--ink);
  }
  .install-hero h1 em { font-style: italic; color: var(--accent); }
  .install-hero .lede {
    font-family: var(--serif-body);
    font-size: 19px;
    line-height: 1.65;
    color: var(--ink-2);
  }

  .install-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    padding: 56px 0 48px;
    border-bottom: 1px solid var(--rule);
  }
  .install-steps h2 {
    font-family: var(--serif-display);
    font-weight: 400;
    font-size: 22px;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--ink);
  }
  .install-steps h2 small {
    display: inline-block;
    margin-left: 10px;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 600;
  }
  .install-steps ol {
    margin: 0;
    padding-left: 18px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
  }
  .install-steps li { margin: 8px 0; }
  .install-steps b { color: var(--ink); font-weight: 600; }

  .tip {
    margin: 48px 0 0;
    padding: 24px 28px;
    border-left: 2px solid var(--accent);
    font-family: var(--serif-display);
    font-style: italic;
    font-size: 20px;
    line-height: 1.5;
    color: var(--ink);
    max-width: 64ch;
  }

  @media (max-width: 980px) {
    .install-steps { grid-template-columns: 1fr; gap: 32px; padding: 40px 0; }
  }
</style>
