---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getBlogs, getPosts } from '../lib/site-data';

const blogs = getBlogs();
const posts = getPosts();

const categorySet = new Set<string>();
blogs.forEach((b) => (b.categories || []).forEach((c: string) => categorySet.add(c)));

const sevenDaysAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;
const newThisWeek = posts.filter((p) => new Date(p.date).getTime() >= sevenDaysAgo).length;
---

<Base title="About — smallweb" description="A hand-curated reader for independent writers who still believe an essay is worth an afternoon.">
  <Header currentPath="/about" tag="on restraint, curation, and the quieter corners of the internet" />

  <main>

    <section class="about-hero">
      <aside class="side-left">
        <span class="side-label">A note</span>
        This page exists so the project can explain itself, once.
        <div class="ornament"></div>
        Everything else should be the work.
      </aside>

      <div class="about-title">
        <span class="eyebrow" data-cat="tech">About · colophon</span>
        <h1>A quieter way to <em>read</em> the web.</h1>
        <p class="tagline">A hand-curated reader for independent writers who still believe an essay is worth an afternoon.</p>
      </div>

      <aside class="side-right">
        <span class="side-label">Right now</span>
        <div class="about-stat"><em class="figures">{blogs.length}</em></div>
        <div class="side-prose">writers, <b class="figures">{categorySet.size}</b> departments, <b class="figures">{posts.length.toLocaleString()}</b> essays indexed.</div>
      </aside>
    </section>

    <section class="about-prose">
      <aside class="side-prose">
        <span class="side-label">What this is</span>
        A reader, not a platform.
        <div class="ornament"></div>
        We don't host the writing. We just point at it.
      </aside>

      <div class="prose">
        <p>Smallweb gathers essays from {blogs.length} writers who keep their own blogs, update them at their own pace, and almost always post something worth reading. There is no algorithm choosing what you see. There is no "engagement" column, no reading streak, no feed that doubles in length while you look away. The front page has a lead story, three category columns, a feature, and a departments index — and that is all.</p>

        <p>Every writer in the library has been added by hand. Most of them are essayists, a few are programmers with opinions, a surprising number are retired professors. What they share is that <strong>they post when they have something to say</strong>, and are usually willing to wait until they do.</p>

        <h2>Why it exists</h2>

        <p>Because the web used to be a place you <em>visited</em>, not a place you were <em>served</em>. You opened five or six bookmarks in the morning; you came back to them after dinner; you closed the laptop. The writers you followed had names, faces, and the distinct habit of posting things at inconvenient times of day. That is still true of a few hundred corners of the internet, but they are harder to find than they used to be.</p>

        <blockquote>The small web is still here. It's just quieter.</blockquote>

        <p>Smallweb is an attempt to build a room where that quieter web can still be visited. The design is editorial, not social. There are no comments, no upvotes, no share buttons. If you see something you want to talk about, you'll have to do it yourself, somewhere else.</p>

        <h2>How it works</h2>

        <p>The library is a JSON file. A scheduled job fetches each writer's RSS feed every few hours, pulls in any new posts, and writes the result to a cache that the site reads at render time. Nothing is stored except titles, excerpts, dates, and links — we don't copy or serve the writing itself. When you click a post, you leave smallweb and read it where it was published, on the writer's own site. That is the polite way to do it.</p>

        <p>The code is on <a href="https://github.com/bebhuvan/smallweb-blog" target="_blank" rel="noopener">GitHub</a>; the writers are in <a href="/blogs">the library</a>. If you have a blog you think belongs here — or if one of ours has been quiet for too long — write to <a href="mailto:hello@smallweb.blog">hello@smallweb.blog</a>.</p>
      </div>

      <aside class="side-prose right">
        <span class="side-label">Colophon</span>
        Set in Fraunces, Source Serif 4, and Inter Tight.
        <div class="ornament"></div>
        Built with Astro, running on Cloudflare.
      </aside>
    </section>

    <section class="numbers">
      <div class="n">
        <span class="n-label">Writers</span>
        <div class="n-val"><em class="figures">{blogs.length}</em></div>
        <div class="n-note">hand-picked, hand-watched.</div>
      </div>
      <div class="n">
        <span class="n-label">Departments</span>
        <div class="n-val figures">{categorySet.size}</div>
        <div class="n-note">from tech to philosophy.</div>
      </div>
      <div class="n">
        <span class="n-label">Essays indexed</span>
        <div class="n-val figures">{posts.length.toLocaleString()}</div>
        <div class="n-note">only titles &amp; links stored.</div>
      </div>
      <div class="n">
        <span class="n-label">New this week</span>
        <div class="n-val"><em class="figures">{newThisWeek}</em></div>
        <div class="n-note">refreshed every few hours.</div>
      </div>
    </section>

  </main>

  <Footer left="About · smallweb" colophon="A quieter way to read the web." />
</Base>

<style>
  /* ─── page-local: about page ─── */
  .about-hero {
    display: grid;
    grid-template-columns: 180px 1fr 220px;
    gap: 56px;
    padding-bottom: 72px;
    border-bottom: 1px solid var(--rule);
  }
  .side-left, .side-right, .side-prose {
    font-family: var(--serif-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-2);
    font-style: italic;
  }
  .about-hero .side-left { text-align: right; padding-top: 18px; }
  .about-hero .side-right { padding-top: 18px; }

  .about-title h1 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: clamp(48px, 8vw, 104px);
    line-height: 0.86;
    letter-spacing: -0.035em;
    margin: 14px 0 28px;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    color: var(--ink);
  }
  .about-title h1 em { font-style: italic; color: var(--accent); }
  .about-title .tagline {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(20px, 2.6vw, 26px);
    line-height: 1.35;
    color: var(--ink-2);
    margin: 0 0 4px;
    max-width: 44ch;
    font-variation-settings: "opsz" 144;
  }

  .side-right .about-stat {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: 46px;
    line-height: 1;
    color: var(--ink);
    font-variation-settings: "opsz" 144;
  }
  .side-right .about-stat em { font-style: italic; color: var(--accent); }

  .about-prose {
    display: grid;
    grid-template-columns: 180px 1fr 220px;
    gap: 56px;
    padding: 80px 0 40px;
  }
  .about-prose .prose {
    font-family: var(--serif-body);
    font-size: 19px;
    line-height: 1.72;
    color: var(--ink-2);
    max-width: 62ch;
  }
  .about-prose .prose p { margin: 0 0 26px; }
  .about-prose .prose p:first-of-type::first-letter {
    font-family: var(--serif-display);
    float: left;
    font-size: 82px;
    line-height: 0.82;
    padding: 10px 14px 0 0;
    color: var(--accent);
    font-weight: 400;
    font-style: italic;
    font-variation-settings: "opsz" 144;
  }
  .about-prose .prose strong { color: var(--ink); font-weight: 600; }
  .about-prose .prose em { font-style: italic; }
  .about-prose .prose a { color: var(--accent); border-bottom: 1px solid var(--rule); }
  .about-prose .prose a:hover { border-bottom-color: var(--accent); }
  .about-prose .prose h2 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: 36px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 48px 0 20px;
    font-variation-settings: "opsz" 144;
  }
  .about-prose .prose h2::before {
    content: "";
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 14px;
  }
  .about-prose .prose blockquote {
    margin: 32px 0;
    padding: 0 0 0 28px;
    border-left: 2px solid var(--accent);
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: 24px;
    line-height: 1.4;
    color: var(--ink);
    font-variation-settings: "opsz" 144;
  }
  .side-prose.right { padding-top: 4px; }

  .numbers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    margin-top: 72px;
  }
  .numbers .n {
    padding: 40px 28px 44px;
    border-right: 1px solid var(--rule);
  }
  .numbers .n:last-child { border-right: 0; }
  .numbers .n-label {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 20px;
    display: block;
  }
  .numbers .n-val {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: 56px;
    line-height: 0.9;
    color: var(--ink);
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144;
  }
  .numbers .n-val em { font-style: italic; color: var(--accent); }
  .numbers .n-note {
    margin-top: 12px;
    font-family: var(--serif-display);
    font-style: italic;
    font-size: 14px;
    color: var(--dim);
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .about-hero, .about-prose {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 40px 0;
    }
    .about-hero .side-left, .about-hero .side-right { text-align: left; padding-top: 0; }
    .about-title h1 { font-size: clamp(44px, 12vw, 72px); }
    .about-prose .prose { font-size: 17px; }
    .numbers { grid-template-columns: 1fr 1fr; }
    .numbers .n { border-right: 0; border-bottom: 1px solid var(--rule); padding: 28px 20px 32px; }
    .numbers .n:nth-child(odd) { border-right: 1px solid var(--rule); }
    .numbers .n:nth-last-child(-n+2) { border-bottom: 0; }
    .numbers .n-val { font-size: 44px; }
  }
</style>
