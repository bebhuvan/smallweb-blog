---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getBlogMap, getBlogs, getEnrichedPosts } from '../lib/site-data';
import { curateHomepage } from '../lib/homepage';
import { CATEGORIES, CATEGORY_MAP, HOMEPAGE_CATEGORY_SLUGS, type CategorySlug } from '../lib/categories';
import { formatDate } from '../lib/dates';

const blogs = getBlogs();
const blogMap = getBlogMap(blogs);
const enrichedPosts = getEnrichedPosts({ blogs, blogMap });
const { leadPost, categoryPosts, featuredExcerpt, archivePicks, alsoNew } = curateHomepage(enrichedPosts, blogMap);

function splitItalic(name: string): [string, string] {
  const n = name.length;
  const tailLen = n <= 4 ? 1 : n <= 6 ? 2 : 3;
  return [name.slice(0, n - tailLen), name.slice(n - tailLen)];
}

function truncate(text: string | undefined, max: number) {
  if (!text) return '';
  const t = text.trim();
  return t.length <= max ? t : `${t.slice(0, max).trimEnd()}…`;
}

function readingMinutes(post: { excerpt?: string }) {
  const words = (post.excerpt || '').split(/\s+/).length;
  return Math.max(1, Math.round(words / 200) + 8);
}

function shortDate(dateStr: string) {
  const d = new Date(dateStr);
  if (Number.isNaN(d.getTime())) return '';
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function romanize(n: number) {
  const map: [number, string][] = [
    [10, 'X'], [9, 'IX'], [5, 'V'], [4, 'IV'], [1, 'I'],
  ];
  let out = '';
  let num = n;
  for (const [v, s] of map) {
    while (num >= v) { out += s; num -= v; }
  }
  return out;
}

// Columns — one per homepage category, 3 most-recent posts each.
const columns = HOMEPAGE_CATEGORY_SLUGS.map((slug, i) => {
  const cat = CATEGORY_MAP.get(slug);
  const curated = categoryPosts.get(slug) || [];
  const posts = curated.length > 0
    ? curated.slice(0, 5)
    : enrichedPosts.filter((p) => p.category === slug).slice(0, 5);
  const [head, tail] = splitItalic(cat?.name || slug);
  return {
    slug,
    name: cat?.name || slug,
    head,
    tail,
    numeral: romanize(i + 1),
    posts,
  };
}).filter((col) => col.posts.length > 0);

// Also-today picks — diversify across categories, skipping the lead's category.
const alsoDiverse = (() => {
  const picks: typeof alsoNew = [];
  const seen = new Set<string>();
  if (leadPost?.category) seen.add(leadPost.category);
  for (const p of enrichedPosts) {
    if (p === leadPost) continue;
    if (seen.has(p.category)) continue;
    picks.push(p);
    seen.add(p.category);
    if (picks.length >= 3) break;
  }
  return picks;
})();

// Feature — use featuredExcerpt if present, else the 2nd freshest prose post.
const feature = featuredExcerpt
  || enrichedPosts.find((p) => p !== leadPost && (p.excerpt?.length || 0) > 120)
  || null;

const freshCount = enrichedPosts.filter((p) => {
  const d = new Date(p.date).getTime();
  return Date.now() - d < 1000 * 60 * 60 * 48;
}).length;
---

<Base title="smallweb — a quieter way to read the web" jsonLd={{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "The Small Web",
  "url": "https://smallweb.blog",
  "description": "A curated collection of indie blogs. Hand-picked writing from independent voices."
}}>
  <Header currentPath="/" />

  <main>

    {leadPost && (
      <section class="hero">
        <aside class="side-left">
          <span class="side-label">Today</span>
          {freshCount} essays in the room.
          <div class="ornament"></div>
          Nothing is ranked or scored. Move at your own pace.
        </aside>

        <article class="lead-body">
          <span class="eyebrow" data-cat={leadPost.category}>
            {CATEGORY_MAP.get(leadPost.category as CategorySlug)?.name || leadPost.category} · Long read
          </span>
          <h1>
            <a href={leadPost.link} target="_blank" rel="noopener noreferrer">{leadPost.title}</a>
          </h1>
          {leadPost.excerpt && (
            <p class="lede">{truncate(leadPost.excerpt, 340)}</p>
          )}
          <div class="byline">
            <span>By <b>{leadPost.blogName}</b></span>
            <span class="figures">{readingMinutes(leadPost)} min</span>
            <span class="figures">{formatDate(leadPost.date)}</span>
          </div>
        </article>

        {leadPost.excerpt && (
          <aside class="side-right">
            <span class="side-label">Marginalia</span>
            <q>{truncate(leadPost.excerpt, 140)}</q>
            <div class="ornament"></div>
            See also {blogs.length} writers across ten shelves in the library.
          </aside>
        )}
      </section>
    )}

    {alsoDiverse.length > 0 && (
      <section class="also-today">
        <aside class="at-rail">
          <span class="side-label">Also today</span>
          <p class="at-blurb">Three fresh pieces, each from a different room.</p>
        </aside>

        <ol class="at-row">
          {alsoDiverse.map((post) => (
            <li class="at-item" data-cat={post.category}>
              <a href={post.link} target="_blank" rel="noopener noreferrer">
                <span class="eyebrow" data-cat={post.category}>
                  {CATEGORY_MAP.get(post.category as CategorySlug)?.name || post.category}
                </span>
                <h4 class="at-title">{post.title}</h4>
                <div class="at-meta">
                  <span class="at-writer">{post.blogName}</span>
                  <span class="figures">{shortDate(post.date)}</span>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}

    <div class="section-divider" aria-hidden="true">
      <span>·&ensp;·&ensp;·</span>
    </div>

    <section class="columns">
      <div class="section-head">
        <small>Ten shelves · {columns.reduce((n, c) => n + c.posts.length, 0)} essays</small>
        <h2>The <em>Reading Room</em></h2>
      </div>
      <div class="columns-grid">
        {columns.map((col, ci) => (
          <div class="col" data-cat={col.slug}>
            <div class="col-head">
              <span class="col-numeral">{col.numeral}.</span>
              <h3><a href={`/category/${col.slug}`}>{col.head}<em>{col.tail}</em></a></h3>
            </div>
            <div class="col-body">
              {col.posts.map((post, pi) => (
                <article class:list={['story', pi === 0 && 'story-lead']}>
                  <h4>
                    <a href={post.link} target="_blank" rel="noopener noreferrer">{post.title}</a>
                  </h4>
                  {pi === 0 && post.excerpt && (
                    <p class="story-excerpt">{truncate(post.excerpt, 120)}</p>
                  )}
                  <div class="meta">
                    <a href={`/blog/${post.blogId}`} class="meta-writer">{post.blogName}</a>
                    <span class="figures">{shortDate(post.date)}</span>
                  </div>
                </article>
              ))}
            </div>
            <a class="col-foot" href={`/category/${col.slug}`}>All {col.name.toLowerCase()} →</a>
          </div>
        ))}
      </div>
    </section>

    {feature && (
      <section class="feature">
        <aside class="side-left">
          <span class="side-label">The feature</span>
          {readingMinutes(feature)} minutes of long-form.
          <div class="ornament"></div>
          Filed in {CATEGORY_MAP.get(feature.category as CategorySlug)?.name || feature.category}.
        </aside>

        <div class="feature-body">
          <span class="eyebrow" data-cat={feature.category}>
            {CATEGORY_MAP.get(feature.category as CategorySlug)?.name || feature.category} · Feature
          </span>
          <h2>
            <a href={feature.link} target="_blank" rel="noopener noreferrer">{feature.title}</a>
          </h2>
          {feature.excerpt && <p class="first">{truncate(feature.excerpt, 420)}</p>}
          <div class="byline">
            <span>By <b>{feature.blogName}</b></span>
            <span class="figures">{readingMinutes(feature)} min</span>
            <span class="figures">{formatDate(feature.date)}</span>
          </div>
        </div>

        {feature.excerpt && (
          <aside class="side-right">
            <span class="side-label">A passage</span>
            <q>{truncate(feature.excerpt, 160)}</q>
            <div class="ornament"></div>
            Part of a longer piece on the writer's own site.
          </aside>
        )}
      </section>
    )}

    <div class="interlude" aria-hidden="true">
      <p>Not everything worth reading was written today.</p>
      <span class="int-orn"></span>
    </div>

    {archivePicks.length > 0 && (
      <section class="coda">
        <div class="coda-head">
          <small class="coda-label">From the Stacks</small>
          <h2 class="coda-title">Five rediscoveries from the back issues, rotated by the day</h2>
          <p class="coda-sub">Read slowly. There is no hurry.</p>
          <div class="coda-orn"></div>
        </div>
        <ol class="coda-grid">
          {archivePicks.map((post, i) => (
            <li class="coda-card" data-cat={post.category}>
              <a href={post.link} target="_blank" rel="noopener noreferrer">
                <span class="coda-num">{romanize(i + 1)}.</span>
                <span class="eyebrow" data-cat={post.category}>
                  {CATEGORY_MAP.get(post.category as CategorySlug)?.name || post.category}
                </span>
                <h3 class="coda-card-title">{post.title}</h3>
                <div class="coda-card-meta">
                  <span>{post.blogName}</span>
                  <span class="figures">{shortDate(post.date)}</span>
                </div>
              </a>
            </li>
          ))}
        </ol>
        <a class="coda-footer" href="/archive">Browse the full archive &rarr;</a>
      </section>
    )}

  </main>

  <Footer />
</Base>

<style>
  /* ─── page-local: homepage composition ─── */

  /* ─── section divider ─── */
  .section-divider {
    text-align: center;
    padding: 40px 0;
    color: var(--dim);
    font-family: var(--serif-display);
    font-size: 14px;
    letter-spacing: 0.5em;
    font-weight: 300;
    font-variation-settings: "opsz" 144;
    opacity: 0.7;
  }

  /* ─── hero ─── */
  .hero {
    display: grid;
    grid-template-columns: 180px 1fr 220px;
    gap: 56px;
    align-items: start;
    padding-bottom: 72px;
    border-bottom: 1px solid var(--rule);
  }
  .side-left, .side-right {
    font-family: var(--serif-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-2);
    font-style: italic;
  }
  .side-left  { text-align: right; padding-top: 18px; }
  .side-right { padding-top: 18px; }

  .lead-body h1 {
    font-family: var(--serif-display);
    font-weight: 200;
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.94;
    letter-spacing: -0.035em;
    margin: 22px 0 28px;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    color: var(--ink);
  }
  .lead-body h1 a { color: inherit; }
  .lead-body h1 a:hover { color: var(--accent); }
  .lede {
    font-size: 20px;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 58ch;
    margin: 0 0 24px;
  }
  .lede::first-letter {
    font-family: var(--serif-display);
    float: left;
    font-size: 92px;
    line-height: 0.82;
    padding: 12px 14px 0 0;
    color: var(--accent);
    font-weight: 400;
    font-style: italic;
    font-variation-settings: "opsz" 144;
  }
  .side-right q {
    quotes: "\201C" "\201D";
    display: block;
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: 18px;
    line-height: 1.38;
    font-style: italic;
    color: var(--ink);
    font-variation-settings: "opsz" 144;
  }

  /* ─── also today — three fresh picks under the hero ─── */
  .also-today {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 56px;
    padding: 52px 0 56px;
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }
  .at-rail { text-align: right; padding-top: 4px; }
  .at-rail .side-label { margin-bottom: 12px; }
  .at-rail .at-blurb {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: 15.5px;
    line-height: 1.45;
    color: var(--ink-2);
    margin: 0;
    margin-left: auto;
    max-width: 22ch;
    font-variation-settings: "opsz" 144;
  }
  .at-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 44px;
  }
  .at-item {
    padding: 18px 24px 0 0;
    border-right: 1px solid var(--rule-soft);
    border-top: 2px solid var(--at-color, var(--accent));
  }
  .at-item:last-child { border-right: 0; padding-right: 0; }
  .at-item[data-cat="tech"]       { --at-color: var(--tech); }
  .at-item[data-cat="culture"]    { --at-color: var(--culture); }
  .at-item[data-cat="economics"]  { --at-color: var(--economics); }
  .at-item[data-cat="finance"]    { --at-color: var(--finance); }
  .at-item[data-cat="life"]       { --at-color: var(--life); }
  .at-item[data-cat="philosophy"] { --at-color: var(--philosophy); }
  .at-item[data-cat="psychology"] { --at-color: var(--psychology); }
  .at-item[data-cat="design"]     { --at-color: var(--design); }
  .at-item[data-cat="history"]    { --at-color: var(--history); }
  .at-item[data-cat="science"]    { --at-color: var(--science); }
  .at-item a { display: block; color: inherit; }
  .at-item .eyebrow { font-size: 9.5px; }
  .at-title {
    font-family: var(--serif-display);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.22;
    letter-spacing: -0.012em;
    margin: 14px 0 12px;
    color: var(--ink);
    transition: color 180ms ease;
    font-variation-settings: "opsz" 144, "SOFT" 20;
  }
  .at-item a:hover .at-title { color: var(--accent); }
  .at-meta {
    font-family: var(--serif-body);
    font-style: italic;
    font-size: 13px;
    color: var(--ink-2);
    display: flex;
    gap: 10px;
    align-items: baseline;
  }
  .at-meta .figures {
    font-family: var(--sans);
    font-style: normal;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
  }

  /* ─── reading room ─── */
  .columns {
    padding: 104px 0 112px;
  }
  .columns .section-head {
    margin-bottom: 80px;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border-bottom: none;
    padding-bottom: 0;
    gap: 12px;
  }
  .columns .section-head small { order: -1; }
  .columns .section-head h2 {
    font-size: clamp(32px, 4.4vw, 44px);
    font-weight: 200;
    font-variation-settings: "opsz" 144, "SOFT" 50;
  }
  .columns .section-head::after {
    content: "";
    display: block;
    width: 56px;
    height: 1px;
    background: var(--accent);
    margin-top: 4px;
  }

  .columns-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 80px 56px;
  }

  .col {
    position: relative;
    display: flex;
    flex-direction: column;
    --col-color: var(--ink);
  }
  @media (min-width: 981px) {
    .col::before {
      content: "";
      position: absolute;
      top: 4px;
      bottom: 4px;
      left: -28px;
      width: 1px;
      background: var(--rule-soft);
    }
  }
  @media (min-width: 981px) and (max-width: 1079px) {
    .col:nth-child(2n+1)::before { display: none; }
  }
  @media (min-width: 1080px) {
    .col:nth-child(3n+1)::before { display: none; }
  }
  .col[data-cat="tech"]       { --col-color: var(--tech); }
  .col[data-cat="culture"]    { --col-color: var(--culture); }
  .col[data-cat="economics"]  { --col-color: var(--economics); }
  .col[data-cat="finance"]    { --col-color: var(--finance); }
  .col[data-cat="life"]       { --col-color: var(--life); }
  .col[data-cat="philosophy"] { --col-color: var(--philosophy); }
  .col[data-cat="psychology"] { --col-color: var(--psychology); }
  .col[data-cat="design"]     { --col-color: var(--design); }
  .col[data-cat="history"]    { --col-color: var(--history); }
  .col[data-cat="science"]    { --col-color: var(--science); }

  /* ─ column heading ─ */
  .col-head {
    position: relative;
    padding-bottom: 18px;
    margin-bottom: 30px;
  }
  .col-head::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: var(--col-color);
  }
  .col-numeral {
    display: block;
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--col-color);
    margin-bottom: 8px;
    font-variation-settings: "opsz" 144;
    opacity: 0.9;
  }
  .col-head h3 {
    font-family: var(--serif-display);
    font-weight: 300;
    font-size: 32px;
    line-height: 0.92;
    letter-spacing: -0.025em;
    margin: 0;
    font-variation-settings: "opsz" 144, "SOFT" 30;
    color: var(--ink);
  }
  .col-head h3 a { color: inherit; }
  .col-head h3 a:hover { color: var(--col-color); }
  .col-head h3 em {
    font-style: italic;
    font-weight: 300;
    color: var(--col-color);
  }

  /* ─ stories ─ */
  .col-body { flex: 1; }

  .story { margin-bottom: 22px; }
  .story:last-child { margin-bottom: 0; }
  .story h4 {
    font-family: var(--serif-display);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.28;
    letter-spacing: -0.004em;
    margin: 0 0 6px;
    color: var(--ink);
  }
  .story h4 a { color: inherit; transition: color 160ms ease; }
  .story h4 a:hover { color: var(--accent); }
  .story .meta {
    font-family: var(--serif-body);
    font-style: italic;
    font-size: 13.5px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink-2);
    font-weight: 400;
    display: flex;
    gap: 10px;
    align-items: baseline;
  }
  .story .meta .figures {
    font-family: var(--sans);
    font-style: normal;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--dim);
    text-transform: uppercase;
  }
  .story .meta-writer {
    color: var(--ink-2);
    font-weight: 400;
    border-bottom: 1px solid transparent;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .story .meta-writer:hover {
    color: var(--col-color);
    border-bottom-color: var(--col-color);
  }

  /* ─ lead story per column ─ */
  .story-lead {
    padding-bottom: 24px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .story-lead h4 {
    font-size: 24px;
    line-height: 1.18;
    letter-spacing: -0.014em;
    margin-bottom: 10px;
  }
  .story-excerpt {
    font-family: var(--serif-body);
    font-style: italic;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 12px;
    max-width: 42ch;
  }

  /* ─ column footer ─ */
  .col-foot {
    display: inline-block;
    margin-top: auto;
    padding-top: 22px;
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: 14px;
    letter-spacing: 0.005em;
    color: var(--col-color);
    font-variation-settings: "opsz" 144;
    transition: color 160ms ease, padding-left 200ms ease;
    align-self: flex-start;
  }
  .col-foot:hover { color: var(--accent); padding-left: 4px; }

  /* ─── feature ─── */
  .feature {
    display: grid;
    grid-template-columns: 180px 1fr 220px;
    gap: 56px;
    padding: 96px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: relative;
  }
  .feature::before,
  .feature::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: var(--rule);
  }
  .feature::before { top: 8px; }
  .feature::after  { bottom: 8px; }
  .feature-body h2 {
    font-family: var(--serif-display);
    font-weight: 200;
    font-size: clamp(34px, 4.6vw, 58px);
    line-height: 1;
    letter-spacing: -0.028em;
    margin: 16px 0 26px;
    font-variation-settings: "opsz" 144, "SOFT" 15;
  }
  .feature-body h2 a { color: inherit; }
  .feature-body h2 a:hover { color: var(--accent); }
  .feature-body p {
    font-size: 17px;
    line-height: 1.66;
    color: var(--ink-2);
    margin: 0 0 18px;
    max-width: 60ch;
  }
  .feature-body p.first::first-letter {
    font-family: var(--serif-display);
    float: left;
    font-size: 78px;
    line-height: 0.84;
    padding: 8px 12px 0 0;
    color: var(--accent);
    font-weight: 300;
    font-variation-settings: "opsz" 144;
  }
  .feature .byline { margin-top: 24px; }

  /* ─── interlude ─── */
  .interlude {
    text-align: center;
    padding: 64px 0 56px;
  }
  .interlude p {
    font-family: var(--serif-display);
    font-style: italic;
    font-weight: 300;
    font-size: 17px;
    line-height: 1.6;
    color: var(--dim);
    font-variation-settings: "opsz" 144;
    max-width: 44ch;
    margin: 0 auto;
  }
  .interlude .int-orn {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--rule);
    margin: 20px auto 0;
  }

  /* ─── coda — from the stacks ─── */
  .coda {
