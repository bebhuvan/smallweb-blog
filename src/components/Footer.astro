---
interface Props {
  left?: string;
  colophon?: string;
}

const year = new Date().getFullYear();
const {
  left = `smallweb · ${year}`,
  colophon = 'Set in Fraunces & Source Serif on parchment, with a single carmine accent.',
} = Astro.props;
---

<footer class="page">
  <span>{left}</span>
  <span class="colophon">{colophon}</span>
  <span class="colo-links">
    <a href="/rss.xml">RSS</a>
    <a href="https://github.com/bebhuvan/smallweb-blog" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="/about">About</a>
  </span>
</footer>
