---
import { getSiteStats } from '../lib/site-data';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath?: string;
  tag?: string;
}

const { currentPath = '/', tag = 'a reading room for the unhurried web' } = Astro.props;

const { blogCount } = getSiteStats();

const now = new Date();
const dayOfYear = Math.floor((now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86400000);
const issueNo = dayOfYear;
const weekday = now.toLocaleDateString('en-US', { weekday: 'long' });
const monthDay = now.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
const year = now.getFullYear();

const nav = [
  { href: '/', label: 'Today', match: (p: string) => p === '/' },
  { href: '/feed', label: 'Feed', match: (p: string) => p.startsWith('/feed') },
  { href: '/departments', label: 'Departments', match: (p: string) => p === '/departments' || p.startsWith('/category') },
  { href: '/blogs', label: 'Writers', match: (p: string) => p.startsWith('/blogs') || p.startsWith('/blog/') },
  { href: '/archive', label: 'Archive', match: (p: string) => p.startsWith('/archive') },
  { href: '/about', label: 'About', match: (p: string) => p.startsWith('/about') },
];
---

<header class="masthead">
  <div class="left">
    Vol. II &middot; <b class="figures">No. {issueNo}</b><br />
    Established <b class="figures">2025</b>
  </div>
  <h1 class="title"><a href="/">sm<em>all</em>web</a></h1>
  <div class="right">
    {weekday}, <b class="figures">{monthDay}</b>, {year}<br />
    <b class="figures">{blogCount}</b> writers in the library
  </div>
  <ThemeToggle />
</header>

<div class="subbar">
  <nav>
    {nav.map((n) => (
      <a href={n.href} class={n.match(currentPath) ? 'active' : ''}>{n.label}</a>
    ))}
  </nav>
  <span class="tag"><slot name="tag">{tag}</slot></span>
</div>
