---
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "A reading room for the unhurried web. Hand-picked essays from independent writers who still believe an essay is worth an afternoon — no algorithms, no ads, no feeds that double in length while you look away.",
  ogImage = "/og-image.png",
  ogType = "website",
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://smallweb.blog';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(ogImage, siteUrl).toString();
const swVersion = import.meta.env.PUBLIC_SW_VERSION || new Date().toISOString().slice(0, 10);

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "smallweb",
  "url": siteUrl,
  "description": "A reading room for the unhurried web. Hand-picked essays from independent writers.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteUrl}/archive?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <!-- Font preloads — LCP-critical faces only -->
    <link rel="preload" href="/fonts/fraunces-normal-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fraunces-italic-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/source-serif-4-400-normal-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/source-serif-4-400-italic-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Theme: apply saved preference before paint to prevent flash -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var dark = stored ? stored === 'dark'
            : window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (dark) document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#fbfaf6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#14110d" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Small Web" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="The Small Web" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content="The Small Web — Curated Indie Blogs" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:site" content="@bebhuvan" />
    <meta name="twitter:creator" content="@bebhuvan" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="The Small Web RSS" href="/rss.xml" />

    <!-- Critical CSS for first paint — tokens + base only -->
    <style is:inline>
      :root{--paper:#fbfaf6;--ink:#17130e;--ink-2:#3a322a;--dim:#8a8275;--rule:#e3dccb;--accent:#c94a2e;--serif-display:'Fraunces',Georgia,serif;--serif-body:'Source Serif 4',Georgia,serif;--sans:'Inter Tight',system-ui,sans-serif}
      .dark{--paper:#14110d;--ink:#ece4d0;--ink-2:#b8ae94;--dim:#7c7363;--rule:#2e2820;--accent:#e86a4a}
      *,*::before,*::after{box-sizing:border-box}
      html,body{margin:0;padding:0;background:var(--paper);color:var(--ink);font-family:var(--serif-body);font-size:17px;-webkit-font-smoothing:antialiased}
      body{min-height:100vh;overflow-x:hidden}
      a{color:inherit;text-decoration:none}
    </style>

    <!-- Prefetch key pages -->
    <link rel="prefetch" href="/about" />
    <link rel="prefetch" href="/archive" />
  </head>
  <body>
    <slot />

    <!-- Service Worker Registration -->
    <script is:inline define:vars={{ swVersion }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(`/sw.js?v=${swVersion}`).catch(() => {});
        });
      }
    </script>
  </body>
</html>
